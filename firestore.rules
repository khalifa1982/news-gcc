rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Catch-all safety net (Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Hardened Security Primitives ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isEmailVerified() && (
        request.auth.token.email == 'khalifa@khalifa.net' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validation Helpers ---
    function isValidNewsItem(data) {
      return data.keys().hasAll(['id', 'headline', 'content', 'publishedAt', 'imageUrl', 'sources', 'locationTags', 'categoryTags', 'verifiedStatus'])
        && data.keys().size() == 9
        && data.id is string && data.id.size() <= 128
        && data.headline is string && data.headline.size() <= 256
        && data.content is string && data.content.size() <= 10000
        && data.publishedAt is string
        && data.imageUrl is string && data.imageUrl.size() <= 1024
        && data.sources is list && data.sources.size() <= 20
        && data.locationTags is list && data.locationTags.size() <= 10
        && data.categoryTags is list && data.categoryTags.size() <= 10
        && data.verifiedStatus is string && data.verifiedStatus.size() <= 100;
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'displayName', 'photoURL'])
        && data.keys().size() == 3
        && data.uid is string && data.uid.size() <= 128
        && data.displayName is string && data.displayName.size() <= 100
        && data.photoURL is string && data.photoURL.size() <= 1024;
    }

    function isValidPrivateUserInfo(data) {
      return data.keys().hasAll(['email', 'emailVerified', 'createdAt'])
        && data.keys().size() == 3
        && data.email is string && data.email.size() <= 256
        && data.emailVerified is bool
        && data.createdAt is timestamp;
    }

    // --- Collection Matching Rule Definition ---
    
    // News Collection
    match /news/{newsId} {
      allow read: if true; // Public news feed
      allow create: if isAdmin() && isValidId(newsId) && isValidNewsItem(incoming()) && incoming().id == newsId;
      allow update: if isAdmin() && isValidId(newsId) && isValidNewsItem(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['headline', 'content', 'imageUrl', 'sources', 'locationTags', 'categoryTags', 'verifiedStatus'])
      );
      allow delete: if isAdmin() && isValidId(newsId);
    }

    // Admins helper (if they exist)
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // System bootstrap or cloud only
    }

    // User Public Profile nested structure
    match /users/{userId}/public/profile {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidId(userId) && isValidUserProfile(incoming()) && incoming().uid == userId;
      allow update: if isOwner(userId) && isValidId(userId) && isValidUserProfile(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL'])
      );
      allow delete: if isOwner(userId) && isValidId(userId);
    }

    // User Private sensitive info
    match /users/{userId}/private/info {
      allow read: if isOwner(userId) && isValidId(userId) && isEmailVerified();
      allow create: if isOwner(userId) && isValidId(userId) && isEmailVerified() && isValidPrivateUserInfo(incoming()) && incoming().email == request.auth.token.email && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && isValidId(userId) && isEmailVerified() && isValidPrivateUserInfo(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['emailVerified'])
      );
      allow delete: if isOwner(userId) && isValidId(userId);
    }
  }
}
